# Cloud Function Environment Variables
# Copy this file to .env and fill in real values for local testing.
# In WeChat Cloud Development, these are set via the cloud console.

# PostgreSQL Configuration
PG_HOST=your-db-host.sql.tencentcdb.com
PG_PORT=5432
PG_USER=your_db_user
PG_PASSWORD=your_db_password
PG_DATABASE=your_database
PG_SSL=false

# Important Notes:
# - PG_SSL must be false for hosts that do not support SSL (e.g., Tencent Cloud CDB PostgreSQL basic instances).
# - In WeChat Cloud Development, set these via the cloud console, not this file.
# - This .env file is for local development only and is ignored by the cloud runtime.
